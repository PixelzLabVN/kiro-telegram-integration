{
  "enabled": true,
  "name": "Telegram Agent Done Notification",
  "description": "When the agent finishes processing, send a summary notification to Telegram.",
  "version": "2",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The agent has finished processing. Use the telegram_notify tool to send a notification. Format the message EXACTLY like this template:\n\nв”Њв”Ђ рџЏЃ SESSION COMPLETE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nв”‚\nв”‚ рџ“ќ <what was accomplished in 1 sentence>\nв”‚ рџ“‚ Files: <changed files or 'None'>\nв”‚ рџ•ђ <current time HH:MM>\nв”‚\nв””в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n\nThen stop вЂ” do NOT continue with any other work."
  }
}
